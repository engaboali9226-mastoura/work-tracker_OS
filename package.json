{
  "name": "work-tracker-os",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "./scripts-build.sh",
    "pretest": "npm run build",
    "test": "npm run validate:zero-tests && npm --workspace packages/architecture run build && npm run test --workspaces",
    "forge": "npm --workspace apps/forge run dev --",
    "web": "npm --workspace apps/web run dev",
    "web:build": "npm --workspace apps/web run build",
    "validate:architecture": "./tools/validate-architecture.sh",
    "validate:zero-tests": "node tools/validate-zero-test-workspaces.mjs"
  }
}
